{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the overlay and settings windows",
  "windows": ["overlay", "settings"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-hide",
    "core:window:allow-show"
  ]
}
